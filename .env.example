# Copy this file to .env and fill in your values
# Central Pessoal — Server Configuration

# Port to run the server on (default: 3456)
# PORT=3456

# API authentication token.
# If set, all /api/* routes require Authorization: Bearer <token> header.
# If empty/not set, the API is open (no auth required).
# API_TOKEN=

# Path to SQLite database file (default: central.db in project root)
# DB_PATH=central.db

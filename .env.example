# Central Pessoal — Server Configuration
# Copy this file to .env and fill in your values

# Port to run the server on (default: 3456)
# PORT=3456

# API authentication token.
# If set, all /api/* routes require Authorization: Bearer TOKEN header.
# If empty/not set, the API is open (no auth required).
# API_TOKEN=

# Path to SQLite database file (default: central.db in project root)
# DB_PATH=central.db

# Disable Ollama integration entirely (recommended if you don't use local AI)
# Set to any truthy value (true, 1, yes)
# DISABLE_OLLAMA=true

# Custom Ollama server URL (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Ollama model to use for general AI chat (default: first available model)
# OLLAMA_MODEL=llama3:latest

# Ollama model to use for the Escrita (writing) AI assistant
# Falls back to OLLAMA_MODEL if not set
# ESCRITA_MODEL=llama3:latest

# YouTube Data API v3 key (for search and playlist features)
# YOUTUBE_API_KEY=

# Google Drive API key (for Drive backup feature)
# DRIVE_TOKEN=
